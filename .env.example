# 通用知识库框架 — 环境配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# === AI 模型 API 密钥（可选） ===
# 根据需要配置对应模型的 API 密钥
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here
YI_API_KEY=your_yi_api_key_here

# === MCP Server 配置（可选） ===
# 当作为 MCP Server 运行时启用
# MCP_SERVER_PORT=8080
# MCP_SERVER_HOST=0.0.0.0

# === 系统路径（Windows 自动配置） ===
# TEMP=C:\Windows\Temp
